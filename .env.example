# Domain
# Set this to your production domain (e.g., nodepad.io)
DOMAIN=localhost

# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=https://dashboard.localhost

# Environment: local, staging, production
ENVIRONMENT=production

PROJECT_NAME="Nodepad"
STACK_NAME=nodepad

# Backend
# List allowed origins separated by commas
BACKEND_CORS_ORIGINS="https://localhost,https://dashboard.localhost"
SECRET_KEY=changethis
FIRST_SUPERUSER=admin@nodepad.io
FIRST_SUPERUSER_PASSWORD=changethis

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@nodepad.io
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=nodepad
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

SENTRY_DSN=

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
